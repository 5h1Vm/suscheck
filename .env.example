# ── SUSCHECK CONFIGURATION EXAMPLE ────────────────────────────
# Copy this to .env and fill in your keys.

# ── AI MODELS (Tier 2 Triage)
# Get keys at:
# Groq: https://console.groq.com/keys
# Anthropic: https://console.anthropic.com/settings/keys
# Gemini: https://aistudio.google.com/app/apikey
# Mistral: https://console.mistral.ai/api-keys/
# Sambanova: https://cloud.sambanova.ai/keys
# Cerebras: https://cloud.cerebras.ai/keys
# OpenRouter: https://openrouter.ai/keys/

GROQ_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
SAMBANOVA_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=

# ── SECURITY INTELLIGENCE
# VirusTotal (Hash reputation): https://www.virustotal.com/gui/user/USERNAME/apikey
# AbuseIPDB (IP reputation): https://www.abuseipdb.com/account/api
# GitHub Token (Repo signals): https://github.com/settings/tokens
# NVD Key (CVE lookups): https://nvd.nist.gov/developers/request-an-api-key

SUSCHECK_VT_KEY=
SUSCHECK_ABUSEIPDB_KEY=
SUSCHECK_GITHUB_TOKEN=
SUSCHECK_NVD_KEY=

# ── INTERNAL MAPPING (Usually no need to change)
# The tool checks these variables first; they fallback to the provider keys above if empty.
SUSCHECK_ANTHROPIC_KEY=
SUSCHECK_GEMINI_KEY=
SUSCHECK_OPENAI_KEY=
SUSCHECK_GROQ_KEY=
SUSCHECK_LOG_LEVEL=INFO
SUSCHECK_MAX_FILE_SIZE=52428800
SUSCHECK_OLLAMA_HOST=http://localhost:11434
