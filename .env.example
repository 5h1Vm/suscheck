# ═══════════════════════════════════════════════════════════════
# suscheck — Environment Variables
# ═══════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# The tool loads .env automatically. Keys can also be set as
# regular environment variables (env vars take precedence).
#
# ALL keys are OPTIONAL. Missing key = that service is skipped.
# The tool works fine without any keys — just fewer checks.
# ═══════════════════════════════════════════════════════════════


# ── Tier 0: Hash & Reputation ──────────────────────────────────

# VirusTotal API key (free tier: 4 requests/minute)
# Get yours at: https://www.virustotal.com/gui/join-us
SUSCHECK_VT_KEY=

# AbuseIPDB API key (free tier: 1,000 checks/day)
# Get yours at: https://www.abuseipdb.com/register
SUSCHECK_ABUSEIPDB_KEY=


# ── Supply Chain & Repository Scanning ─────────────────────────

# GitHub personal access token (raises rate limit from 60 to 5,000 req/hr)
# Used for: contributor reputation, repo metadata, supply chain signals
# Create at: https://github.com/settings/tokens (no special scopes needed)
SUSCHECK_GITHUB_TOKEN=

# NVD API key (raises rate limit for CVE lookups)
# Get yours at: https://nvd.nist.gov/developers/request-an-api-key
SUSCHECK_NVD_KEY=


# ── AI Triage (pick ONE provider) ──────────────────────────────
#
# Keys: use either SUSCHECK_AI_KEY (one key for all) OR the usual upstream names below.
# Providers apply 429/503 retries with backoff; free tiers are rate-limited — expect delays.
#
# SUSCHECK_AI_PROVIDER: none | openai | groq | anthropic | gemini | google | openrouter |
#                       mistral | cerebras | sambanova | ollama

SUSCHECK_AI_PROVIDER=none

# Model id (examples; check each vendor’s docs)
SUSCHECK_AI_MODEL=

# Optional unified key (overrides nothing; checked first before provider-specific vars)
SUSCHECK_AI_KEY=

# ---- Provider-specific API keys (use full secrets locally; never commit .env) ----
# OPENAI_API_KEY=          # Get yours at: https://platform.openai.com/api-keys
# GROQ_API_KEY=            # Get yours at: https://console.groq.com/keys
# ANTHROPIC_API_KEY=       # Get yours at: https://console.anthropic.com/settings/keys
# GEMINI_API_KEY=          # Get yours at: https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=          # alternate for Gemini
# OPENROUTER_API_KEY=      # Get yours at: https://openrouter.ai/keys
# MISTRAL_API_KEY=         # Get yours at: https://console.mistral.ai/api-keys/
# CEREBRAS_API_KEY=        # Get yours at: https://cloud.cerebras.ai/
# SAMBANOVA_API_KEY=       # Get yours at: https://cloud.sambanova.ai/

# Optional: force JSON response mode for OpenAI-compatible APIs (default on). Set 0 if provider errors.
# SUSCHECK_AI_JSON_MODE=1

# Optional: override base URL for OpenAI-compatible providers
# SUSCHECK_AI_BASE_URL=https://api.openai.com/v1

# OpenRouter (optional headers; some setups require Referer)
# OPENROUTER_HTTP_REFERER=https://yoursite.example
# OPENROUTER_APP_TITLE=SusCheck

# Examples (model names change often — verify with vendor):
#   openai     → SUSCHECK_AI_MODEL=gpt-4o-mini
#   groq       → SUSCHECK_AI_MODEL=llama-3.3-70b-versatile
#   anthropic  → SUSCHECK_AI_MODEL=claude-3-5-sonnet-20241022
#   gemini     → SUSCHECK_AI_MODEL=gemini-2.0-flash-exp  (use 'google' as provider)
#   openrouter → SUSCHECK_AI_MODEL=google/gemini-2.0-flash-exp:free
#   mistral    → SUSCHECK_AI_MODEL=mistral-large-latest
#   cerebras   → SUSCHECK_AI_MODEL=llama3.1-70b
#   sambanova  → SUSCHECK_AI_MODEL=Llama-3.1-70B-Instruct
#   ollama     → SUSCHECK_AI_MODEL=llama3.3:latest  (no cloud key)

# Ollama host (only if SUSCHECK_AI_PROVIDER=ollama)
SUSCHECK_OLLAMA_HOST=http://localhost:11434

# Planned: fallback chain (not wired yet)
SUSCHECK_AI_FALLBACK_PROVIDER=none
SUSCHECK_AI_FALLBACK_MODEL=


# ── General Settings ───────────────────────────────────────────

# Log level: DEBUG, INFO, WARNING, ERROR
SUSCHECK_LOG_LEVEL=WARNING

# Max file size to scan in bytes (default: 50 MB)
SUSCHECK_MAX_FILE_SIZE=52428800
