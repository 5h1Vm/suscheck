# ── suscheck configuration example ─────────────────────────────
# Rename this to .env and fill in your keys.

# ── Tier 0 & External Intel (Recommended) ──────────────────────

# VirusTotal API Key (Required for hash lookups)
# Get yours at: https://www.virustotal.com/gui/my-apikey
SUSCHECK_VT_KEY=

# AbuseIPDB API Key (Required for IP reputation)
# Get yours at: https://www.abuseipdb.com/account/api
SUSCHECK_ABUSEIPDB_KEY=

# GitHub Token (Optional, increases rate limits for repo scanning)
# Create at: https://github.com/settings/tokens
SUSCHECK_GITHUB_TOKEN=

# NVD API Key (Optional, increases rate limits for CVE lookups)
# Request at: https://nvd.nist.gov/developers/request-an-api-key
SUSCHECK_NVD_KEY=


# ── AI Triage (Optional but highly recommended) ───────────────

# provider: groq, anthropic, google, openai, openrouter, ollama, none
SUSCHECK_AI_PROVIDER=groq

# model: llama-3.3-70b-versatile, claude-3-5-sonnet-20241022, gemini-2.0-flash, gpt-4o, etc.
SUSCHECK_AI_MODEL=llama-3.3-70b-versatile

# Primary AI Key
SUSCHECK_AI_KEY=

# ── Individual Provider Keys (Dashboard Links) ────────────────

# Groq: https://console.groq.com/keys
GROQ_API_KEY=

# Anthropic: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Mistral: https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=

# OpenRouter: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# SambaNova: https://cloud.sambanova.ai/
SAMBANOVA_API_KEY=

# Cerebras: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=


# ── Internal Internal Mapping (Do not change) ────────────────
SUSCHECK_GROQ_KEY=${GROQ_API_KEY}
SUSCHECK_ANTHROPIC_KEY=${ANTHROPIC_API_KEY}
SUSCHECK_GEMINI_KEY=${GEMINI_API_KEY}
SUSCHECK_MISTRAL_KEY=${MISTRAL_API_KEY}
SUSCHECK_OPENROUTER_KEY=${OPENROUTER_API_KEY}
SUSCHECK_SAMBANOVA_KEY=${SAMBANOVA_API_KEY}
SUSCHECK_CEREBRAS_KEY=${CEREBRAS_API_KEY}


# ── General Settings ───────────────────────────────────────────
SUSCHECK_LOG_LEVEL=INFO
SUSCHECK_MAX_FILE_SIZE=52428800
SUSCHECK_REPORT_DIR=./reports/
